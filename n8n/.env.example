POSTGRES_USER=root
POSTGRES_PASSWORD=change-me
POSTGRES_DB=n8n

N8N_ENCRYPTION_KEY=super-secret-key
N8N_USER_MANAGEMENT_JWT_SECRET=even-more-secret

# Shared secret between n8n and the task runner sidecar
N8N_RUNNERS_AUTH_TOKEN=runner-secret-token

